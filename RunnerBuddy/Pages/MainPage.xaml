<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RunnerBuddy.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:modelsRecommendationPlan="clr-namespace:RunnerBuddy.Models.RecommendationPlan"
    xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="MainPageViewModel">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!--  Quick Stats Section  -->
            <HorizontalStackLayout>
                <Image
                    HeightRequest="48"
                    Source="runner.png"
                    WidthRequest="48" />
                <Label
                    FontAttributes="Bold"
                    FontSize="24"
                    Text="RunnerBuddy"
                    TextColor="#1B3039"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!--  Quick Stats Section  -->
            <HorizontalStackLayout>
                <Label
                    FontAttributes="Bold"
                    FontSize="24"
                    Text="Quick Stats"
                    TextColor="#1B3039"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>


            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">
                <Border
                    Grid.Column="0"
                    Padding="12"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Style="{StaticResource BorderShadow}">
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="5"
                        VerticalOptions="Center">
                        <Label
                            FontSize="12"
                            HorizontalOptions="Center"
                            TextColor="Gray">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span FontAttributes="Bold" Text="Weather Now - " />
                                    <Span FontAttributes="Bold" Text="{Binding Location}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span FontAttributes="Bold" Text="{Binding WeatherDescription}" />
                                    <Span FontAttributes="Bold" Text=" (" />
                                    <Span FontAttributes="Bold" Text="{Binding Temperature}" />
                                    <Span FontAttributes="Bold" Text=")" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="12"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Style="{StaticResource BorderShadow}">
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="5"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Text="Air Quality Now"
                            TextColor="Gray" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="{Binding AirQuality}" />
                        <Label
                            FontSize="14"
                            HorizontalOptions="Center"
                            Text="{Binding AirQualityAdditionalInfos}"
                            TextColor="Gray" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="12"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Style="{StaticResource BorderShadow}">
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="5"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Text="Humidity Now"
                            TextColor="Gray" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="{Binding Humidity}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!--  Recommendation Section  -->
            <VerticalStackLayout Spacing="10">
                <Label
                    FontAttributes="Bold"
                    FontSize="24"
                    Text="Get Recommendations"
                    TextColor="#1B3039" />

                <Border
                    Padding="0"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 15"
                    StrokeThickness="0">
                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Opacity="0.1"
                            Radius="10"
                            Offset="0,2" />
                    </Border.Shadow>

                    <Grid RowDefinitions="Auto, Auto">

                        <HorizontalStackLayout
                            Grid.Row="0"
                            Padding="15"
                            Spacing="10"
                            VerticalOptions="Start">

                            <Border
                                HeightRequest="178"
                                HorizontalOptions="Start"
                                StrokeShape="RoundRectangle 25"
                                VerticalOptions="Center"
                                WidthRequest="178">
                                <Grid RowDefinitions="Auto">
                                    <Image
                                        Grid.Row="0"
                                        Aspect="AspectFit "
                                        HeightRequest="140"
                                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                        Source="buddy_icon.png"
                                        WidthRequest="140" />
                                    <skia:SKLottieView
                                        Grid.Row="0"
                                        HeightRequest="100"
                                        IsAnimationEnabled="{Binding IsBusy}"
                                        IsVisible="{Binding IsBusy}"
                                        RepeatCount="-1"
                                        Source="ai_thinking.json"
                                        WidthRequest="100" />
                                </Grid>

                            </Border>

                            <Border
                                Padding="15"
                                BackgroundColor="#006064"
                                MaximumWidthRequest="260"
                                StrokeShape="RoundRectangle 15,15,15,0">
                                <VerticalStackLayout Spacing="5">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        Text="RunnerBuddy"
                                        TextColor="#D1E9FF" />
                                    <Label
                                        FontSize="15"
                                        LineBreakMode="WordWrap"
                                        Text="I’ve locked onto your coordinates in! I’m ready to analyze the weather conditions and other environmental factors in your area to find your best run windows. Not satisfied with my recommendations? Set your preferences and try again! 🏃‍♂️"
                                        TextColor="White" />
                                </VerticalStackLayout>
                            </Border>
                        </HorizontalStackLayout>

                        <Grid
                            Grid.Row="1"
                            Padding="15,10"
                            BackgroundColor="#FAFAFA"
                            ColumnDefinitions="*, Auto"
                            ColumnSpacing="10"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="25"
                            VerticalOptions="End">
                            <Editor
                                Grid.Row="0"
                                Grid.ColumnSpan="2"
                                AutoSize="TextChanges"
                                BackgroundColor="Transparent"
                                Keyboard="Chat"
                                MinimumHeightRequest="50"
                                Placeholder="Not happy with the plan? Give me more detail! Mention your preferred running hours, days to avoid, surface type (treadmill/trail), or if you’re feeling sore/tired and need a lighter week"
                                PlaceholderColor="Gray"
                                Text="{Binding UserInstructions}"
                                VerticalTextAlignment="Center" />
                            <Button
                                Grid.Row="1"
                                Grid.Column="1"
                                BackgroundColor="#006064"
                                Command="{Binding RefreshRunningScheduleCommand}"
                                CornerRadius="22"
                                FontAttributes="Bold"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Text="Refresh Recommendations Now!"
                                TextColor="White">
                                <Button.Triggers>
                                    <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5" />
                                    </Trigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="10">

                <Label
                    FontAttributes="Bold"
                    FontSize="24"
                    Text="Buddy's Best Windows"
                    TextColor="#1B3039" />

                <CollectionView
                    ItemSizingStrategy="MeasureAllItems"
                    ItemsLayout="HorizontalList"
                    ItemsSource="{Binding RecommendationPlan.DailySuggestions}"
                    SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="modelsRecommendationPlan:DaySuggestion">
                            <StackLayout Padding="0" Spacing="12">

                                <!--  Card Container  -->
                                <Border
                                    Margin="16,8"
                                    Padding="0"
                                    BackgroundColor="#FFFFFF"
                                    HeightRequest="500"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0"
                                    WidthRequest="250">

                                    <Border.Shadow>
                                        <Shadow
                                            Brush="#000000"
                                            Opacity="0.08"
                                            Radius="14"
                                            Offset="0,6" />
                                    </Border.Shadow>

                                    <Grid
                                        Padding="20"
                                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                        RowSpacing="12">

                                        <!--  Day  -->
                                        <Label
                                            Grid.Row="0"
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            Text="{Binding Day}"
                                            TextColor="#8E8E93" />

                                        <!--  Time  -->
                                        <Label
                                            Grid.Row="1"
                                            FontAttributes="Bold"
                                            FontSize="26"
                                            Text="{Binding BestStartTime}"
                                            TextColor="#FF9500" />

                                        <!--  Weather Icon  -->
                                        <Image
                                            Grid.Row="2"
                                            HeightRequest="128"
                                            HorizontalOptions="Center"
                                            Source="{Binding WeatherIcon}"
                                            VerticalOptions="Center"
                                            WidthRequest="128" />

                                        <!--  Weather Description  -->
                                        <Label
                                            Grid.Row="3"
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            LineBreakMode="WordWrap"
                                            Text="{Binding WeatherDescription}"
                                            TextColor="#333333" />

                                        <!--  Reason  -->
                                        <Label
                                            Grid.Row="4"
                                            FontSize="14"
                                            LineBreakMode="WordWrap"
                                            MaxLines="3"
                                            Text="{Binding Reason}"
                                            TextColor="#555555" />

                                        <!--  AQI Badge  -->
                                        <Border
                                            Grid.Row="5"
                                            Padding="8,4"
                                            BackgroundColor="#E8F5E9"
                                            HorizontalOptions="Start"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="0">

                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                Text="{Binding Aqi, StringFormat='AQI: {0}'}"
                                                TextColor="#2E7D32" />
                                        </Border>

                                        <!--  Add to Schedule Button  -->
                                        <Button
                                            Grid.Row="6"
                                            Padding="12,8"
                                            BackgroundColor="#006064"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type MainPageViewModel}}, Path=AddToCalendarCommand}"
                                            CommandParameter="{Binding .}"
                                            CornerRadius="25"
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            Text="Add to Calendar"
                                            TextColor="White" />
                                    </Grid>
                                </Border>
                            </StackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Border
                    Padding="15"
                    BackgroundColor="#ffffff"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0">
                    <Grid ColumnDefinitions="Auto, *">
                        <Image
                            Margin="0,0,12,0"
                            Aspect="AspectFit"
                            HeightRequest="84"
                            Source="fox2.png"
                            VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label
                                CharacterSpacing="1"
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="BUDDY TIP"
                                TextColor="#1B3039" />
                            <Label
                                FontSize="16"
                                LineBreakMode="WordWrap"
                                Text="{Binding RecommendationPlan.BuddyTip}"
                                TextColor="#1B3039" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!--  Activity Section  -->
            <Label
                FontAttributes="Bold"
                FontSize="24"
                Text="City Activity"
                TextColor="#1B3039" />
            <Border
                Padding="15"
                BackgroundColor="#FFF5F5"
                Stroke="Red"
                StrokeShape="RoundRectangle 12">
                <CollectionView
                    ItemSizingStrategy="MeasureAllItems"
                    ItemsSource="{Binding RecommendationPlan.LocationActivities}"
                    SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <VerticalStackLayout Spacing="10">
                                <Label
                                    FontSize="18"
                                    Text="⚠️"
                                    VerticalOptions="Center" />
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        FontAttributes="Bold"
                                        Text="ALERTS:"
                                        TextColor="Red" />
                                    <Label
                                        FontSize="12"
                                        Text="{Binding}"
                                        TextColor="#1B3039" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
